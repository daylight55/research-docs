{
  "name": "research-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "test": "vitest run",
    "build:site": "scripts/build-pages-site.sh site",
    "slide:html": "marp slides/example.md --html --theme theme/research.css --output dist/example.html",
    "slide:pdf": "marp slides/example.md --html --theme theme/research.css --pdf --allow-local-files --output dist/example.pdf",
    "slide:verify": "bash scripts/verify-slides.sh slides/example.md",
    "slide:mcp:html": "marp src/content/docs/slides/mcp-internal-presentation.md --html --theme theme/research.css --output dist/mcp-internal-presentation.html",
    "slide:mcp:verify": "bash scripts/verify-slides.sh src/content/docs/slides/mcp-internal-presentation.md"
  },
  "dependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/markdown-remark": "7.2.0",
    "@marp-team/marp-cli": "4.4.0",
    "astro": "6.4.4",
    "rehype-autolink-headings": "7.1.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "playwright": "^1.52.0",
    "vitest": "4.1.8"
  }
}
