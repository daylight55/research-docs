---
import DocsLayout from "../layouts/DocsLayout.astro";
import { deckHref, getDocSummaries, getThemeSummaries, kindLabel } from "../lib/docs";

const docs = await getDocSummaries();
const themes = getThemeSummaries(docs);
---

<DocsLayout
  title="MCP internal presentation"
  description="MCP社内発表向けのスライド、調査メモ、参照元、タスク記録を配布するドキュメントサイト。"
>
  <section class="page-header">
    <p class="eyebrow">Topic-centered research workspace</p>
    <h1>調査テーマを親にして、成果物と作業をまとめる</h1>
    <p>
      slide、research note、source links、research task をそれぞれ独立した一覧にせず、特定の調査テーマ配下に集約する。
      テーマ単位で進捗、根拠、発表資料、次の作業を追える構成にする。
    </p>
    <div class="action-row">
      <a class="primary-action" href={deckHref()}>プレゼンHTMLを見る</a>
      <a class="secondary-action" href={`${import.meta.env.BASE_URL}themes/mcp-internal-presentation/`}>
        テーマ概要を見る
      </a>
    </div>
  </section>

  <section class="theme-groups" aria-label="Research themes">
    {
      themes.map((theme) => (
        <article class="theme-card">
          <div class="theme-card-main">
            <p class="theme-status">{theme.entry.data.status ?? "active"}</p>
            <h2><a href={theme.href}>{theme.title}</a></h2>
            {theme.entry.data.description && <p>{theme.entry.data.description}</p>}
            <dl class="theme-meta">
              {theme.entry.data.owner && (
                <div>
                  <dt>Owner</dt>
                  <dd>{theme.entry.data.owner}</dd>
                </div>
              )}
              {theme.entry.data.updatedAt && (
                <div>
                  <dt>Updated</dt>
                  <dd>{theme.entry.data.updatedAt}</dd>
                </div>
              )}
            </dl>
          </div>

          <div class="artifact-list" aria-label={`${theme.title} artifacts`}>
            {theme.children.map(({ entry, href, title }) => (
              <a class="artifact-link" href={href}>
                <span>{kindLabel(entry.data.kind)}</span>
                <strong>{title}</strong>
                {entry.data.description && <p>{entry.data.description}</p>}
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </section>
</DocsLayout>
