---
import DocsLayout from "../layouts/DocsLayout.astro";
import { deckHref, getDocSummaries, getTopicSummaries, kindLabel } from "../lib/docs";

const docs = await getDocSummaries();
const topics = getTopicSummaries(docs);
---

<DocsLayout
  title="MCP internal presentation"
  description="MCP社内発表向けのスライド、調査メモ、参照元、タスク記録を配布するドキュメントサイト。"
>
  <section class="page-header">
    <p class="eyebrow">Topic-centered research workspace</p>
    <h1>調査トピックを親にして、成果物と作業をまとめる</h1>
    <p>
      slide、research note、source links、research task をそれぞれ独立した一覧にせず、特定の調査トピック配下に集約する。
      トピック単位で進捗、根拠、発表資料、次の作業を追える構成にする。
    </p>
    <div class="action-row">
      <a class="primary-action" href={deckHref()}>プレゼンHTMLを見る</a>
      <a class="secondary-action" href={`${import.meta.env.BASE_URL}topics/mcp-internal-presentation/`}>
        トピック概要を見る
      </a>
    </div>
  </section>

  <section id="research-topics" class="topic-groups" aria-label="Research topics">
    {
      topics.map((topic) => (
        <article class="topic-card">
          <div class="topic-card-main">
            <p class="topic-status">{topic.entry.data.status ?? "active"}</p>
            <h2><a href={topic.href}>{topic.title}</a></h2>
            {topic.entry.data.description && <p>{topic.entry.data.description}</p>}
            <dl class="topic-meta">
              {topic.entry.data.owner && (
                <div>
                  <dt>Owner</dt>
                  <dd>{topic.entry.data.owner}</dd>
                </div>
              )}
              {topic.entry.data.updatedAt && (
                <div>
                  <dt>Updated</dt>
                  <dd>{topic.entry.data.updatedAt}</dd>
                </div>
              )}
            </dl>
          </div>

          <div class="artifact-list" aria-label={`${topic.title} artifacts`}>
            {topic.children.map(({ entry, href, title }) => (
              <a class="artifact-link" href={href}>
                <span>{kindLabel(entry.data.kind)}</span>
                <strong>{title}</strong>
                {entry.data.description && <p>{entry.data.description}</p>}
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </section>
</DocsLayout>
