---
import { getCollection, render } from "astro:content";
import DocsLayout from "../layouts/DocsLayout.astro";
import { deckHref, routeSlug } from "../lib/docs";

export async function getStaticPaths() {
  const entries = await getCollection("docs");

  return entries.map((entry) => ({
    params: { slug: routeSlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const isSlideSource = entry.data.kind === "slides";
---

<DocsLayout title={entry.data.title} description={entry.data.description}>
  <article class="document">
    <header class="doc-header">
      <p class="eyebrow">{entry.data.kind}</p>
      <h1>{entry.data.title}</h1>
      {entry.data.description && <p>{entry.data.description}</p>}
      {
        isSlideSource && (
          <div class="action-row">
            <a class="primary-action" href={deckHref()}>プレゼンHTMLを見る</a>
            <a class="secondary-action" href={`${import.meta.env.BASE_URL}${entry.id}.md`}>Markdownをダウンロード</a>
          </div>
        )
      }
    </header>
    <div class="markdown-body">
      <Content />
    </div>
  </article>
</DocsLayout>
