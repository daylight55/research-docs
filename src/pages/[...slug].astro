---
import { getCollection, render } from "astro:content";
import TableOfContents from "../components/TableOfContents.astro";
import DocsLayout from "../layouts/DocsLayout.astro";
import { deckHref, markdownHrefForSlug, routeSlug } from "../lib/docs";

export async function getStaticPaths() {
  const entries = await getCollection("docs");

  return entries.map((entry) => ({
    params: { slug: routeSlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const isSlideSource = entry.data.kind === "slides";
const markdownHref = markdownHrefForSlug(routeSlug(entry.id));
const hasDocumentIndex = headings.length > 0;
---

<DocsLayout title={entry.data.title} description={entry.data.description}>
  <article class:list={["document", { "document-with-index": hasDocumentIndex }]}>
    <div class="document-content">
      <header class="doc-header">
        <p class="eyebrow">{entry.data.kind}</p>
        <h1>{entry.data.title}</h1>
        {entry.data.description && <p>{entry.data.description}</p>}
        {
          <div class="action-row">
            {isSlideSource && <a class="primary-action" href={deckHref()}>プレゼンHTMLを見る</a>}
            <a class="secondary-action" href={markdownHref}>Raw Markdown</a>
          </div>
        }
      </header>
      <div class="markdown-body">
        <Content />
      </div>
    </div>
    {hasDocumentIndex && (
      <aside class="document-index" aria-label="現在読んでいる箇所">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </article>
</DocsLayout>
