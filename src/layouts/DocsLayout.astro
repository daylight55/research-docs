---
import "../styles/site.css";
import { deckHref, getDocSummaries, getThemeSummaries } from "../lib/docs";

type Props = {
  description?: string;
  sidebarDefaultState?: "open" | "closed";
  title: string;
};

const { description, sidebarDefaultState = "open", title } = Astro.props;
const docs = await getDocSummaries();
const themes = getThemeSummaries(docs);
const currentPath = Astro.url.pathname;
const deckUrl = deckHref();
const researchLog = docs.find((doc) => doc.entry.data.kind === "research");
const llmsHref = `${import.meta.env.BASE_URL}llms.txt`.replace(/\/{2,}/g, "/");

function isActive(href: string) {
  return currentPath.endsWith(new URL(href, Astro.url).pathname);
}

function isThemeActive(theme: (typeof themes)[number]) {
  return isActive(theme.href) || theme.children.some((item) => isActive(item.href));
}
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? "Research documents and slide materials."} />
    <title>{title} | research-docs</title>
  </head>
  <body>
    <div class="site-shell" data-sidebar={sidebarDefaultState} data-sidebar-default={sidebarDefaultState}>
      <header class="topbar">
        <button
          class="sidebar-toggle"
          type="button"
          aria-controls="theme-sidebar"
          aria-expanded={sidebarDefaultState === "open" ? "true" : "false"}
          data-sidebar-toggle
        >
          <span class="sidebar-toggle-icon" aria-hidden="true"></span>
          <span class="visually-hidden">調査テーマ一覧を開閉する</span>
        </button>
        <a class="brand" href={import.meta.env.BASE_URL}>
          <span class="brand-mark">RD</span>
          <span>
            <strong>research-docs</strong>
            <small>Research themes and reports</small>
          </span>
        </a>
        <nav class="top-actions" aria-label="Primary">
          <a href={`${import.meta.env.BASE_URL}#research-themes`}>Themes</a>
          <a href={deckUrl}>Slide deck</a>
          {researchLog && <a href={researchLog.href}>Research log</a>}
          <a href={llmsHref}>llms.txt</a>
        </nav>
      </header>

      <div class="content-grid">
        <aside id="theme-sidebar" class="sidebar" aria-label="Research theme navigation">
          <div class="sidebar-title">Research themes</div>
          {
            themes.map((theme) => (
              <section class="nav-section" aria-label={theme.title}>
                <h2><a class:list={[{ active: isThemeActive(theme) }]} href={theme.href}>{theme.title}</a></h2>
              </section>
            ))
          }
        </aside>

        <main class="main-panel">
          <slot />
        </main>
      </div>
    </div>
    <script>
      const shell = document.querySelector(".site-shell");
      const toggle = document.querySelector("[data-sidebar-toggle]");
      const sidebar = document.querySelector("#theme-sidebar");
      const defaultState = shell?.getAttribute("data-sidebar-default") ?? "open";
      const responsiveState = window.matchMedia("(max-width: 900px)").matches ? "closed" : "open";
      const preferredState = responsiveState === "closed" ? "closed" : defaultState;

      function setSidebarState(state) {
        shell?.setAttribute("data-sidebar", state);
        toggle?.setAttribute("aria-expanded", String(state === "open"));
        if (sidebar instanceof HTMLElement) {
          sidebar.inert = state !== "open";
        }
      }

      setSidebarState(preferredState);

      toggle?.addEventListener("click", () => {
        const nextState = shell?.getAttribute("data-sidebar") === "open" ? "closed" : "open";
        setSidebarState(nextState);
      });
    </script>
  </body>
</html>
