---
import "../styles/site.css";
import { deckHref, getDocSummaries, getThemeSummaries, kindLabel } from "../lib/docs";

type Props = {
  description?: string;
  title: string;
};

const { description, title } = Astro.props;
const docs = await getDocSummaries();
const themes = getThemeSummaries(docs);
const currentPath = Astro.url.pathname;
const deckUrl = deckHref();
const llmsHref = `${import.meta.env.BASE_URL}llms.txt`.replace(/\/{2,}/g, "/");

function isActive(href: string) {
  return currentPath.endsWith(new URL(href, Astro.url).pathname);
}
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? "Research documents and slide materials."} />
    <title>{title} | research-docs</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href={import.meta.env.BASE_URL}>
          <span class="brand-mark">RD</span>
          <span>
            <strong>research-docs</strong>
            <small>MCP internal presentation</small>
          </span>
        </a>
        <nav class="top-actions" aria-label="Primary">
          <a href={deckUrl}>Slide deck</a>
          <a href={`${import.meta.env.BASE_URL}sources/mcp-source-links/`}>Sources</a>
          <a href={llmsHref}>llms.txt</a>
        </nav>
      </header>

      <div class="content-grid">
        <aside class="sidebar" aria-label="Document navigation">
          <div class="sidebar-title">Research themes</div>
          {
            themes.map((theme) => (
              <section class="nav-section" aria-label={theme.title}>
                <h2><a class:list={[{ active: isActive(theme.href) }]} href={theme.href}>{theme.title}</a></h2>
                <ul>
                  {theme.children.map((item) => (
                    <li>
                      <a class:list={[{ active: isActive(item.href) }]} href={item.href}>
                        <span>{kindLabel(item.entry.data.kind)}</span>
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </aside>

        <main class="main-panel">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
